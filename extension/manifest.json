{
  "manifest_version": 3,
  "name": "a11ytest.ai",
  "version": "1.0.0",
  "description": "Scan the current tab for accessibility issues and add them to your a11ytest.ai backlog.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/a11y16.png",
    "32": "icons/a11y32.png",
    "48": "icons/a11y48.png",
    "128": "icons/a11y128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open a11ytest.ai",
    "default_icon": {
      "16": "icons/a11y16.png",
      "32": "icons/a11y32.png",
      "48": "icons/a11y48.png"
    }
  },
  "options_ui": {
    "page": "options.html"
  }
}
